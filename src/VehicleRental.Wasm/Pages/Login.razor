@page "/login"
@attribute [AllowAnonymous]
@inject BrowserAuthenticationStateProvider AuthService
@inject NavigationManager Nav

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card esports-card mt-5 p-4">
            <h2 class="text-center mb-4">登入</h2>

            @if (_registered)
            {
                <AlertMessage Message="帳號已建立，請登入。" Type="success" />
            }

            <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="form-label">電子郵件</label>
                    <InputText @bind-Value="_model.Email" type="email" class="form-control" placeholder="you@example.com" />
                    <ValidationMessage For="() => _model.Email" class="text-danger small" />
                </div>

                <div class="mb-3">
                    <label class="form-label">密碼</label>
                    <InputText @bind-Value="_model.Password" type="password" class="form-control" placeholder="您的密碼" />
                    <ValidationMessage For="() => _model.Password" class="text-danger small" />
                </div>

                <div class="mb-3 form-check">
                    <InputCheckbox @bind-Value="_model.RememberMe" class="form-check-input" id="rememberMe" />
                    <label class="form-check-label text-muted small" for="rememberMe">記住我</label>
                </div>

                <AlertMessage Message="@_error" Type="danger" />

                <button type="submit" class="btn btn-primary w-100 mt-2" disabled="@_busy">
                    @(_busy ? "登入中…" : "登入")
                </button>
            </EditForm>

            <p class="text-center mt-3 text-muted small">
                沒有帳號？<a href="register">立即註冊</a>
            </p>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "registered")]
    public string? RegisteredParam { get; set; }

    private readonly LoginModel _model = new();
    private string? _error;
    private bool _busy;
    private bool _registered;

    protected override void OnInitialized()
    {
        _registered = RegisteredParam == "1";
    }

    private async Task HandleSubmit()
    {
        _busy = true;
        _error = null;

        var ok = await AuthService.LoginAsync(_model.Email!, _model.Password!, _model.RememberMe);

        if (ok)
            Nav.NavigateTo("", forceLoad: false);
        else
            _error = "電子郵件或密碼不正確。";

        _busy = false;
    }

    private sealed class LoginModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "請輸入電子郵件")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "電子郵件格式不正確")]
        public string? Email { get; set; }

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "請輸入密碼")]
        public string? Password { get; set; }

        public bool RememberMe { get; set; }
    }
}
