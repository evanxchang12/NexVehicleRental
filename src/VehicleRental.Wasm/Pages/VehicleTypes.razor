@page "/vehicles"
@attribute [Authorize]
@inject IMediator Mediator

<h2 class="mb-4">車型清單</h2>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border esports-spinner" role="status"></div>
    </div>
}
else if (_vehicles.Count == 0)
{
    <p class="text-muted">目前沒有可用車型。</p>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var v in _vehicles)
        {
            <div class="col">
                <div class="card esports-card h-100">
                    @if (!string.IsNullOrEmpty(v.ImageUrl))
                    {
                        <img src="@v.ImageUrl" class="card-img-top" alt="@v.Name" style="height:200px;object-fit:cover;" />
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@v.Name</h5>
                        <p class="card-text flex-grow-1">@v.Description</p>
                        <div class="d-flex align-items-center justify-content-between mt-3">
                            <span class="esports-price">NT$ @v.DailyRate.ToString("N0") / 天</span>
                            @if (v.IsAvailable)
                            {
                                <a href="reservation/create/@v.Id" class="btn btn-success esports-btn-success btn-sm">立即預約</a>
                            }
                            else
                            {
                                <span class="badge bg-secondary">暫不供應</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<VehicleRental.Application.DTOs.VehicleTypeDto> _vehicles = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _vehicles = (await Mediator.Send(new VehicleRental.Application.Queries.GetVehicleTypes.GetVehicleTypesQuery())).ToList();
        _loading = false;
    }
}
