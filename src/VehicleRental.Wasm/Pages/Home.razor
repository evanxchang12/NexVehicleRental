@page "/"
@attribute [Authorize]
@inject BrowserAuthenticationStateProvider AuthService

<div class="text-center py-5">
    <h1 class="display-4 mb-3">歡迎回來，@AuthService.CurrentCustomerName！</h1>
    <p class="lead text-muted">選擇您理想中的座駕，開啟您的旅程。</p>
    <div class="mt-4 d-flex justify-content-center gap-3 flex-wrap">
        <a href="/vehicles" class="btn btn-success esports-btn-success btn-lg px-5">瀏覽車型</a>
        <a href="/reservation/my" class="btn btn-outline-light btn-lg px-5">我的預約</a>
    </div>
</div>

