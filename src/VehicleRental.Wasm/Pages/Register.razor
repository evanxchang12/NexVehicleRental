@page "/register"
@attribute [AllowAnonymous]
@inject IMediator Mediator
@inject NavigationManager Nav

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card esports-card mt-5 p-4">
            <h2 class="text-center mb-4">建立帳號</h2>

            <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="form-label">姓名</label>
                    <InputText @bind-Value="_model.FullName" class="form-control" placeholder="您的全名" />
                    <ValidationMessage For="() => _model.FullName" class="text-danger small" />
                </div>

                <div class="mb-3">
                    <label class="form-label">電子郵件</label>
                    <InputText @bind-Value="_model.Email" type="email" class="form-control" placeholder="you@example.com" />
                    <ValidationMessage For="() => _model.Email" class="text-danger small" />
                </div>

                <div class="mb-3">
                    <label class="form-label">密碼</label>
                    <InputText @bind-Value="_model.Password" type="password" class="form-control" placeholder="至少 6 個字元" />
                    <ValidationMessage For="() => _model.Password" class="text-danger small" />
                </div>

                <AlertMessage Message="@_error" Type="danger" />

                <button type="submit" class="btn btn-primary w-100 mt-2" disabled="@_busy">
                    @(_busy ? "處理中…" : "註冊")
                </button>
            </EditForm>

            <p class="text-center mt-3 text-muted small">
                已有帳號？<a href="/login">登入</a>
            </p>
        </div>
    </div>
</div>

@code {
    private readonly RegisterModel _model = new();
    private string? _error;
    private bool _busy;

    private async Task HandleSubmit()
    {
        _busy = true;
        _error = null;

        var ok = await Mediator.Send(new VehicleRental.Application.Commands.RegisterCustomer.RegisterCustomerCommand(
            _model.FullName!, _model.Email!, _model.Password!));

        if (ok)
            Nav.NavigateTo("/login?registered=1");
        else
            _error = "此電子郵件已被使用，請嘗試其他電子郵件。";

        _busy = false;
    }

    private sealed class RegisterModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "請輸入姓名")]
        public string? FullName { get; set; }

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "請輸入電子郵件")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "電子郵件格式不正確")]
        public string? Email { get; set; }

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "請輸入密碼")]
        [System.ComponentModel.DataAnnotations.MinLength(6, ErrorMessage = "密碼至少 6 個字元")]
        public string? Password { get; set; }
    }
}
