@page "/reservation/create/{VehicleTypeId:int}"
@attribute [Authorize]
@inject IMediator Mediator
@inject BrowserAuthenticationStateProvider AuthService
@inject NavigationManager Nav

<h2 class="mb-4">建立預約</h2>

@if (_loading)
{
    <div class="text-center py-4">
        <div class="spinner-border esports-spinner" role="status"></div>
    </div>
}
else if (_vehicle is null)
{
    <AlertMessage Message="找不到此車型。" Type="danger" />
    <a href="vehicles" class="btn btn-outline-light mt-3">返回車型清單</a>
}
else
{
    <div class="row">
        <div class="col-md-7">
            <div class="card esports-card p-4">
                <h5 class="card-title">@_vehicle.Name</h5>
                <p class="text-muted">@_vehicle.Description</p>
                <p>日租金：<span class="esports-price">NT$ @_vehicle.DailyRate.ToString("N0")</span></p>

                <hr class="border-secondary" />

                <VehicleRental.Wasm.Components.DateRangePicker
                    @bind-StartDate="_startDate"
                    @bind-EndDate="_endDate" />

                @if (_startDate != default && _endDate != default && _endDate > _startDate)
                {
                    <div class="mt-3 p-3 rounded" style="background:#1a1a2e;border:1px solid var(--neon-green)">
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">租期天數</span>
                            <strong>@(_endDate.DayNumber - _startDate.DayNumber) 天</strong>
                        </div>
                        <div class="d-flex justify-content-between mt-1">
                            <span class="text-muted">預估費用</span>
                            <strong class="esports-price">NT$ @((_vehicle.DailyRate * (_endDate.DayNumber - _startDate.DayNumber)).ToString("N0"))</strong>
                        </div>
                    </div>
                }

                <AlertMessage Message="@_error" Type="danger" />

                <button class="btn btn-success esports-btn-success w-100 mt-4"
                        @onclick="HandleSubmit"
                        disabled="@(!CanSubmit || _busy)">
                    @(_busy ? "送出中…" : "確認預約")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int VehicleTypeId { get; set; }

    private VehicleRental.Application.DTOs.VehicleTypeDto? _vehicle;
    private DateOnly _startDate;
    private DateOnly _endDate;
    private string? _error;
    private bool _busy;
    private bool _loading = true;

    private bool CanSubmit => _startDate != default && _endDate != default && _endDate > _startDate;

    protected override async Task OnInitializedAsync()
    {
        var vehicles = await Mediator.Send(new VehicleRental.Application.Queries.GetVehicleTypes.GetVehicleTypesQuery());
        _vehicle = vehicles.FirstOrDefault(v => v.Id == VehicleTypeId);
        _loading = false;
    }

    private async Task HandleSubmit()
    {
        var customerId = AuthService.CurrentCustomerId;
        if (customerId is null) { Nav.NavigateTo("login"); return; }

        _busy = true;
        _error = null;

        var result = await Mediator.Send(new VehicleRental.Application.Commands.CreateReservation.CreateReservationCommand(
            customerId.Value, VehicleTypeId, _startDate, _endDate));

        if (result.Success)
            Nav.NavigateTo($"reservation/confirmation/{result.ReservationId}");
        else
            _error = result.Error ?? "預約失敗，請稍後再試。";

        _busy = false;
    }
}
