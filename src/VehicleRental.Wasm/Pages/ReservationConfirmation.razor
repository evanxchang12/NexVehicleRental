@page "/reservation/confirmation/{ReservationId:int}"
@attribute [Authorize]
@inject IMediator Mediator
@inject BrowserAuthenticationStateProvider AuthService

<div class="text-center py-5">
    @if (_loading)
    {
        <div class="spinner-border esports-spinner" role="status"></div>
    }
    else if (_reservation is null)
    {
        <AlertMessage Message="找不到預約記錄。" Type="danger" />
        <a href="reservation/my" class="btn btn-outline-light mt-3">我的預約</a>
    }
    else
    {
        <div class="mb-4">
            <span class="display-1" style="color:var(--neon-green)">&#10003;</span>
            <h2 class="mt-3">預約成功！</h2>
            <p class="text-muted">您的預約已確認</p>
        </div>

        <div class="card esports-card mx-auto p-4" style="max-width:480px;text-align:left">
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">預約編號</span>
                <strong>@_reservation.ReservationNumber</strong>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">車型</span>
                <strong>@_reservation.VehicleTypeName</strong>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">取車日期</span>
                <strong>@_reservation.StartDate.ToString("yyyy/MM/dd")</strong>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">還車日期</span>
                <strong>@_reservation.EndDate.ToString("yyyy/MM/dd")</strong>
            </div>
            <hr class="border-secondary" />
            <div class="d-flex justify-content-between">
                <span class="text-muted">總費用</span>
                <span class="esports-price">NT$ @_reservation.TotalCost.ToString("N0")</span>
            </div>
        </div>

        <div class="mt-4 d-flex justify-content-center gap-3">
            <a href="reservation/my" class="btn btn-outline-light">我的預約</a>
            <a href="vehicles" class="btn btn-success esports-btn-success">繼續瀏覽車型</a>
        </div>
    }
</div>

@code {
    [Parameter] public int ReservationId { get; set; }

    private VehicleRental.Application.DTOs.ReservationSummaryDto? _reservation;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var customerId = AuthService.CurrentCustomerId;
        if (customerId is not null)
        {
            var reservations = await Mediator.Send(
                new VehicleRental.Application.Queries.GetMyReservations.GetMyReservationsQuery(customerId.Value));
            _reservation = reservations.FirstOrDefault(r => r.Id == ReservationId);
        }
        _loading = false;
    }
}
