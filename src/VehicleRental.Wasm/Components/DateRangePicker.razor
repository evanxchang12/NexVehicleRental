@* Simple date range picker component using HTML date inputs *@

<div class="row g-2">
    <div class="col-md-6">
        <label class="form-label">取車日期</label>
        <input type="date"
               class="form-control"
               value="@StartDateStr"
               min="@TodayStr"
               @onchange="OnStartChanged" />
    </div>
    <div class="col-md-6">
        <label class="form-label">還車日期</label>
        <input type="date"
               class="form-control"
               value="@EndDateStr"
               min="@MinEndStr"
               @onchange="OnEndChanged" />
    </div>
</div>

@if (Days > 0)
{
    <p class="mt-2 text-muted small">租期：<strong>@Days 天</strong></p>
}

@code {
    [Parameter] public DateOnly StartDate { get; set; }
    [Parameter] public EventCallback<DateOnly> StartDateChanged { get; set; }
    [Parameter] public DateOnly EndDate { get; set; }
    [Parameter] public EventCallback<DateOnly> EndDateChanged { get; set; }

    private string TodayStr => DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd");
    private string StartDateStr => StartDate == default ? string.Empty : StartDate.ToString("yyyy-MM-dd");
    private string EndDateStr   => EndDate   == default ? string.Empty : EndDate.ToString("yyyy-MM-dd");
    private string MinEndStr    => StartDate == default ? TodayStr : StartDate.ToString("yyyy-MM-dd");
    private int    Days         => (StartDate != default && EndDate != default && EndDate >= StartDate)
                                       ? Math.Max(1, EndDate.DayNumber - StartDate.DayNumber) : 0;

    private async Task OnStartChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var d))
        {
            await StartDateChanged.InvokeAsync(d);
            // Reset end if it's no longer valid
            if (EndDate != default && EndDate < d)
                await EndDateChanged.InvokeAsync(default);
        }
    }

    private async Task OnEndChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var d))
            await EndDateChanged.InvokeAsync(d);
    }
}
