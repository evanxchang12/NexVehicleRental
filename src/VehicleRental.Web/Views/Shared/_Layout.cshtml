<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " | " : "")NEXDRIVE 車輛租用</title>
    <!-- Bootstrap 5.1 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <!-- 電競主題 -->
    <link rel="stylesheet" href="~/css/esports.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- 導覽列 -->
    <nav class="navbar navbar-expand-lg navbar-esports sticky-top">
        <div class="container-xl">
            <a class="navbar-brand-esports" asp-controller="Home" asp-action="Index">
                <i class="bi bi-lightning-charge-fill me-1"></i>NEXDRIVE
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Reservation" asp-action="Index">
                                <i class="bi bi-car-front me-1"></i>租車
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Reservation" asp-action="My">
                                <i class="bi bi-calendar-check me-1"></i>我的預約
                            </a>
                        </li>
                        <li class="nav-item ms-lg-2">
                            <span class="nav-link" style="color:var(--text-muted)">
                                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                            </span>
                        </li>
                        <li class="nav-item">
                            <form method="post" asp-controller="Account" asp-action="Logout" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-esports btn-esports-sm ms-1">
                                    <i class="bi bi-box-arrow-right me-1"></i>登出
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>登入
                            </a>
                        </li>
                        <li class="nav-item ms-lg-1">
                            <a class="btn-esports btn-esports-sm" asp-controller="Account" asp-action="Register">
                                <i class="bi bi-person-plus me-1"></i>立即註冊
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- 全域訊息 -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="container-xl mt-3">
            <div class="alert-esports-success alert p-3">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            </div>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="container-xl mt-3">
            <div class="alert-esports-danger alert p-3">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            </div>
        </div>
    }

    <!-- 主要內容 -->
    <main>
        @RenderBody()
    </main>

    <!-- 頁尾 -->
    <footer class="footer-esports mt-5">
        <span>© 2026 <span class="neon-text-green">NEXDRIVE</span> 車輛租用系統 | MVP v1.0</span>
    </footer>

    <!-- Bootstrap 5.1 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
