@model VehicleTypeListViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "選擇車型";
}

<div class="container-xl py-4">
    <h2 class="section-title"><i class="bi bi-car-front me-2"></i>選擇車型</h2>

    @if (!Model.VehicleTypes.Any())
    {
        <div class="esports-card text-center py-5">
            <div style="font-size:3rem;color:var(--text-muted)"><i class="bi bi-car-front"></i></div>
            <p class="mt-3" style="color:var(--text-muted)">目前無可用車輛，請稍後再試</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var vehicle in Model.VehicleTypes)
            {
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="esports-card h-100 d-flex flex-column">
                        <!-- 車輛圖示 -->
                        <div class="vehicle-card-img">
                            @if (!string.IsNullOrEmpty(vehicle.ImageUrl))
                            {
                                <img src="@vehicle.ImageUrl" alt="@vehicle.Name" style="width:100%;height:100%;object-fit:cover;border-radius:4px" />
                            }
                            else
                            {
                                <i class="bi bi-car-front-fill" style="color:var(--text-muted)"></i>
                            }
                        </div>

                        <!-- 車型資訊 -->
                        <h5 class="mb-1" style="color:var(--text-primary);font-family:'Rajdhani',sans-serif;font-weight:700">
                            @vehicle.Name
                        </h5>
                        <p style="color:var(--text-muted);font-size:.9rem;flex-grow:1">@vehicle.Description</p>

                        <hr class="esports-divider" />

                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <span style="color:var(--text-muted);font-size:.8rem">每日租金</span><br />
                                <span class="daily-rate-badge">NT$ @vehicle.DailyRate.ToString("N0")</span>
                            </div>
                            @if (vehicle.IsAvailable)
                            {
                                <a asp-action="Create" asp-route-vehicleTypeId="@vehicle.Id"
                                   class="btn-esports btn-esports-sm">
                                    <i class="bi bi-check2-circle me-1"></i>選擇
                                </a>
                            }
                            else
                            {
                                <span class="badge-esports-unavailable">目前無可用</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
