@model MyReservationsViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "我的預約";
}

<div class="container-xl py-4">
    <h2 class="section-title"><i class="bi bi-list-check me-2"></i>我的預約</h2>

    @if (!Model.Reservations.Any())
    {
        <div class="esports-card text-center py-5">
            <div style="font-size:3rem;color:var(--text-muted)"><i class="bi bi-calendar-x"></i></div>
            <p class="mt-3" style="color:var(--text-muted)">您目前沒有任何預約紀錄</p>
            <a asp-action="Index" class="btn-esports btn-esports-sm mt-2">
                <i class="bi bi-car-front me-1"></i>立即租車
            </a>
        </div>
    }
    else
    {
        <div class="esports-card p-0" style="overflow:hidden">
            <div class="table-responsive">
                <table class="table table-esports mb-0">
                    <thead>
                        <tr>
                            <th>預約編號</th>
                            <th>車型</th>
                            <th>起始日</th>
                            <th>結束日</th>
                            <th>總租金</th>
                            <th>狀態</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Reservations)
                        {
                            <tr>
                                <td style="font-family:'Orbitron',sans-serif;font-size:.8rem;color:var(--neon-green)">
                                    @r.ReservationNumber
                                </td>
                                <td>@r.VehicleTypeName</td>
                                <td>@r.StartDate.ToString("yyyy/MM/dd")</td>
                                <td>@r.EndDate.ToString("yyyy/MM/dd")</td>
                                <td style="font-weight:700">NT$ @r.TotalCost.ToString("N0")</td>
                                <td>
                                    @if (r.Status == "已確認")
                                    {
                                        <span class="badge-esports-confirmed">@r.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge-esports-cancelled">@r.Status</span>
                                    }
                                </td>
                                <td>
                                    @if (r.CanCancel)
                                    {
                                        <form method="post" asp-action="Cancel" asp-route-id="@r.Id"
                                              onsubmit="return confirm('確定要取消此預約？')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-esports btn-esports-sm btn-esports-danger">
                                                <i class="bi bi-x-circle me-1"></i>取消
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
